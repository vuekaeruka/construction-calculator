                    </div>

                    <div class="form-section" id="dimensions-section">
                        <h3 class="section-title">Габариты строения</h3>
                        <div class="input-group">
                            <input type="number" id="build-length" placeholder=" " min="2" max="100" step="0.1" required>
                            <label for="build-length">Общая длина строения, м</label>
                        </div>
                        <div class="input-group">
                            <input type="number" id="build-width" placeholder=" " min="2" max="100" step="0.1" required>
                            <label for="build-width">Общая ширина строения, м</label>
                        </div>
                        
                        <div id="strip-params" class="dynamic-param-block active">
                            <h4 class="subsection-title">Параметры ленты</h4>
                            <div class="input-group">
                                <input type="number" id="strip-total-length" placeholder=" " min="10" max="500" step="0.1">
                                <label for="strip-total-length">Общая длина ленты, м</label>
                            </div>
                            <div class="input-group">
                                <input type="number" id="strip-width" placeholder=" " min="200" max="1000" step="10">
                                <label for="strip-width">Ширина ленты, мм</label>
                            </div>
                            <div class="input-group">
                                <input type="number" id="strip-depth" placeholder=" " min="0.2" max="3" step="0.1">
                                <label for="strip-depth">Глубина заложения, м</label>
                            </div>
                            <div class="input-group">

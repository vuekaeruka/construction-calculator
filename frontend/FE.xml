                                <option value="m200">М200 (B15)</option>
                                <option value="m250" selected>М250 (B20)</option>
                                <option value="m300">М300 (B22.5)</option>
                                <option value="m350">М350 (B25)</option>
                            </select>
                        </div>
                        <div class="input-group">
                            <input type="number" id="sand-cushion" placeholder=" " min="0" max="500" step="10" value="200">
                            <label for="sand-cushion">Песчаная подушка, мм</label>
                        </div>
                    </div>

                    <div class="form-section">
                        <label class="toggle-switch-wrapper">
                            <input type="checkbox" id="toggle-rebar" class="toggle-input" checked>

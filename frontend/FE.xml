                                <label for="strip-height">Высота цоколя (над землей), м</label>
                            </div>
                        </div>

                        <div id="pile-params" class="dynamic-param-block" style="display: none;">
                            <h4 class="subsection-title">Параметры свай</h4>
                            <div class="input-group">
                                <input type="number" id="pile-count" placeholder=" " min="4" max="200" step="1">
                                <label for="pile-count">Количество свай, шт</label>
                            </div>
                            <div class="input-group">
                                <input type="number" id="pile-length" placeholder=" " min="1" max="10" step="0.5">
                                <label for="pile-length">Длина сваи, м</label>
                            </div>
                            <div class="input-group select-group">
                                <label class="static-label">Диаметр / Сечение сваи</label>
                                <select id="pile-diameter" class="custom-select">

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Расчет каркаса | Строительный калькулятор</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header class="navbar">
        <div class="navbar-container">
            <div class="logo">Логотип</div>
            <div class="user-profile">
                <div class="user-info-text">
                    <span class="user-name">Менеджер</span>
                    <span class="user-role">Отдел продаж</span>
                </div>
                <div class="avatar">М</div>
            </div>
        </div>
    </header>

    <main class="container">
        <header class="page-header">
            <div class="header-left">
                <a href="../client-card/index.html" class="btn-back" title="Вернуться в карточку клиента">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="19" y1="12" x2="5" y2="12"></line>
                        <polyline points="12 19 5 12 12 5"></polyline>
                    </svg>
                </a>
                <h1 class="page-title">Каркас</h1>
            </div>
            <div class="header-actions">
                <button type="button" class="btn-secondary" id="clear-calc-btn">Очистить расчет</button>
            </div>
        </header>

        <div class="client-mini-card">
            <div class="client-details">
                <span class="label">Клиент:</span>
                <strong id="client-name">Тестовый Тест Тестович</strong>
                <span class="sub-text" id="client-phone">тел. 8-900-000-00-00</span>
            </div>
        </div>

        <form id="calc-frame-form" class="calc-form">
            <div class="form-section address-section">
                <div class="input-row">
                    <div class="input-group" style="flex: 1;">
                        <input type="text" id="object-address" placeholder=" " required>
                        <label for="object-address">Ввести адрес объекта строительства</label>
                    </div>
                    <button type="button" class="btn-primary btn-sm" id="save-address-btn">Сохранить</button>
                </div>
            </div>

            <div class="form-grid">
                <div class="form-column">
                    <div class="form-section">
                        <h3 class="section-title">Исходные данные</h3>
                        <div class="input-group">
                            <input type="number" id="floors" placeholder=" " min="1" max="3" value="1" required>
                            <label for="floors">Количество этажей</label>
                        </div>
                        
                        <h4 class="subsection-title">1 этаж:</h4>
                        <div class="input-group">
                            <input type="number" id="wall-height" placeholder=" " min="2" max="10" step="0.1" required>
                            <label for="wall-height">Высота стен, м</label>
                        </div>
                        <div class="input-group">
                            <input type="number" id="perimeter" placeholder=" " min="10" max="500" step="0.1" required>
                            <label for="perimeter">Периметр внешних стен, м</label>
                        </div>
                        <div class="input-group">
                            <input type="number" id="glazing" placeholder=" " min="0" max="200" step="0.1">
                            <label for="glazing">Площадь остекления, м²</label>
                        </div>
                        
                        <div class="input-group select-group">
                            <label class="static-label">Толщина внешних стен</label>
                            <select id="ext-wall-thickness" class="custom-select">
                                <option value="150">150 мм</option>
                                <option value="200">200 мм</option>
                                <option value="250">250 мм</option>
                            </select>
                        </div>

                        <div class="input-group">
                            <input type="number" id="int-wall-length" placeholder=" " min="0" max="500" step="0.1">
                            <label for="int-wall-length">Длина внутренних стен, м</label>
                        </div>
                        
                        <div class="input-group select-group">
                            <label class="static-label">Толщина внутренних стен</label>
                            <select id="int-wall-thickness" class="custom-select">
                                <option value="100">100 мм</option>
                                <option value="150">150 мм</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-section">
                        <h3 class="section-title">Обшивка внешних стен</h3>
                        <div class="input-group select-group">
                            <label class="static-label">ОСБ</label>
                            <select id="osb-type" class="custom-select">
                                <option value="9">ОСБ 9 мм</option>
                                <option value="12">ОСБ 12 мм</option>
                                <option value="none">Без ОСБ</option>
                            </select>
                        </div>
                        <div class="input-group select-group">
                            <label class="static-label">Пароизоляция</label>
                            <select id="vapor-barrier" class="custom-select">
                                <option value="standard">Стандартная мембрана</option>
                                <option value="premium">Премиум мембрана</option>
                            </select>
                        </div>
                        <div class="input-group select-group">
                            <label class="static-label">Ветрозащита</label>
                            <select id="wind-protection" class="custom-select">
                                <option value="standard">Стандартная ветрозащита</option>
                                <option value="premium">Премиум ветрозащита</option>
                            </select>
                        </div>
                        <div class="input-group select-group">
                            <label class="static-label">Утеплитель</label>
                            <select id="insulation" class="custom-select">
                                <option value="minvata">Мин. вата</option>
                                <option value="basalt">Базальтовая вата</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-column">
                    <div class="form-section">
                        <label class="toggle-switch-wrapper">
                            <input type="checkbox" id="toggle-doors-windows" class="toggle-input">
                            <span class="toggle-slider"></span>
                            <h3 class="section-title toggle-title">Учесть двери и окна</h3>
                        </label>
                        
                        <div class="collapsible-content" id="doors-windows-content">
                            <h4 class="subsection-title">Наружные двери</h4>
                            <div class="dimensions-row">
                                <div class="input-group"><input type="number" id="ext-door-h" placeholder=" " min="0.5" max="5" step="0.01"><label for="ext-door-h">Высота, м</label></div>
                                <div class="input-group"><input type="number" id="ext-door-w" placeholder=" " min="0.5" max="5" step="0.01"><label for="ext-door-w">Ширина, м</label></div>
                                <div class="input-group"><input type="number" id="ext-door-q" placeholder=" " min="1" max="50"><label for="ext-door-q">Кол-во</label></div>
                            </div>

                            <h4 class="subsection-title">Внутренние двери</h4>
                            <div class="dimensions-row">
                                <div class="input-group"><input type="number" id="int-door-h" placeholder=" " min="0.5" max="5" step="0.01"><label for="int-door-h">Высота, м</label></div>
                                <div class="input-group"><input type="number" id="int-door-w" placeholder=" " min="0.5" max="5" step="0.01"><label for="int-door-w">Ширина, м</label></div>
                                <div class="input-group"><input type="number" id="int-door-q" placeholder=" " min="1" max="100"><label for="int-door-q">Кол-во</label></div>
                            </div>

                            <h4 class="subsection-title">Окна</h4>
                            <div class="dimensions-row">
                                <div class="input-group"><input type="number" id="win-h" placeholder=" " min="0.3" max="5" step="0.01"><label for="win-h">Высота, м</label></div>
                                <div class="input-group"><input type="number" id="win-w" placeholder=" " min="0.3" max="5" step="0.01"><label for="win-w">Ширина, м</label></div>
                                <div class="input-group"><input type="number" id="win-q" placeholder=" " min="1" max="100"><label for="win-q">Кол-во</label></div>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <label class="toggle-switch-wrapper">
                            <input type="checkbox" id="toggle-floors" class="toggle-input">
                            <span class="toggle-slider"></span>
                            <h3 class="section-title toggle-title">Добавить расчет перекрытий</h3>
                        </label>
                        
                        <div class="collapsible-content" id="floors-content">
                            <div class="input-group">
                                <input type="number" id="floor-thickness" placeholder=" " min="10" max="500" step="10">
                                <label for="floor-thickness">Толщина перекрытия, мм</label>
                            </div>
                            <div class="input-group select-group">
                                <label class="static-label">ОСБ</label>
                                <select id="floor-osb" class="custom-select">
                                    <option value="18">ОСБ 18 мм</option>
                                    <option value="22">ОСБ 22 мм</option>
                                </select>
                            </div>
                            <div class="input-group select-group">
                                <label class="static-label">Пароизоляция</label>
                                <select id="floor-vapor" class="custom-select"><option value="standard">Стандартная</option></select>
                            </div>
                            <div class="input-group select-group">
                                <label class="static-label">Ветрозащита</label>
                                <select id="floor-wind" class="custom-select"><option value="standard">Стандартная</option></select>
                            </div>
                            <div class="input-group select-group">
                                <label class="static-label">Утеплитель</label>
                                <select id="floor-insulation" class="custom-select"><option value="minvata">Мин. вата</option></select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary btn-large">Рассчитать</button>
            </div>
        </form>
    </main>

    <script src="script.js"></script>
</body>
</html>
